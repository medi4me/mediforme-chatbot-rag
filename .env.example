# 평가·실행에 필요한 환경변수 템플릿입니다. `cp .env.example .env` 후 채워 넣으세요.
# `.env` 는 .gitignore 에 포함되어 커밋되지 않습니다.

# --- 외부 API ---
OPENAI_API_KEY=

# openFDA
OPENFDA_API_KEY=
OPENFDA_BASE_URL=https://api.fda.gov

# --- 데이터베이스 (pgvector) ---
DATABASE_URL=postgresql://mediforme:mediforme@localhost:5432/mediforme_rag

# --- 서비스 ---
APP_ENV=local
LOG_LEVEL=INFO

# --- 임베딩 모델 ---
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072